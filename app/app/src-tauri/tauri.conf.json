{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JuliaLab",
  "version": "0.1.0",
  "identifier": "org.julialab.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JuliaLab 2026",
        "width": 1024,
        "height": 768,
        "visible": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "frame-src": "'self'",
        "connect-src": "'self' http://127.0.0.1:* http://localhost:*",
        "img-src": "'self' data: http://127.0.0.1:* http://localhost:*"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": [
      "nsis",
      "app",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../demo": "demo",
      "../internals/scripts/core/julialab.dll": "julialab.dll"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "template": "./windows/installer.nsi"
      }
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/applications/julialab.desktop": "./linux/template.desktop",
          "/usr/share/icons/hicolor/32x32/apps/julialab.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/julialab.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/julialab.png": "icons/256x256.png",
          "/usr/share/icons/hicolor/512x512/apps/julialab.png": "icons/512x512.png"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/applications/julialab.desktop": "./linux/template.desktop",
          "/usr/share/icons/hicolor/32x32/apps/julialab.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/julialab.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/julialab.png": "icons/256x256.png",
          "/usr/share/icons/hicolor/512x512/apps/julialab.png": "icons/512x512.png"
        }
      }
    }
  },
  "plugins": {
    "http": {
      "active": true,
      "scope": [
        "http://127.0.0.1:*",
        "http://localhost:*"
      ]
    }
  }
}